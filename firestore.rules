rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net - Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }

    // Leads validation and access
    match /leads/{leadId} {
      allow read, write: if true;
    }

    // Tasks validation and access
    match /tasks/{taskId} {
      allow read, write: if true;
    }

    // Campaigns validation and access
    match /campaigns/{campaignId} {
      allow read, write: if true;
    }

    // Templates validation and access
    match /templates/{templateId} {
      allow read, write: if true;
    }

    // Workflows validation and access
    match /workflows/{workflowId} {
      allow read, write: if true;
    }

    // Settings (User isolated)
    match /settings/{userId} {
      allow read, write: if true;
    }

    // Team members check
    match /team-members/{memberId} {
      allow read, write: if true;
    }

    // Audit logs tracking
    match /audit-logs/{logId} {
      allow read, write: if true;
    }
  }
}
